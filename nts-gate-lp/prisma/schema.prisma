// API と同様、外部ソースの欠損を許容する（NOT NULL を乱用しない・rawPayload で後追い可能）。
// https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// jGrants 等から同期する補助金レコード。必須は id のみ。欠損は null。
model SubsidyGrant {
  id                 String   @id @default(cuid())
  externalId         String?  @unique
  name               String?
  maxAmountLabel     String?
  deadlineLabel      String?
  targetIndustryNote String?  @db.Text
  targetUseNote      String?  @db.Text
  rawPayload         Json?
  targetIndustries   String[] @default([])
  description        String?  @db.Text
  syncedAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt // auto-updated by Prisma (DB default is for initial fill)
  syncRunId          String?

  syncRun SubsidySyncRun? @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@index([syncedAt])
  @@index([updatedAt])
}

/// 同期ジョブの実行単位（部分成功も status で表現可能）。
model SubsidySyncRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String
  itemCount    Int?
  errorMessage String?   @db.Text

  grants SubsidyGrant[]
}
